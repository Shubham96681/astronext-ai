JWT_SECRET=astronext-dev-secret-change-in-production
DATABASE_URL=sqlite:///./astronext.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
# Keep SQLite for now; switch to Postgres in production.
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/astronext

# Schema/seed controls
SEED_DEMO_DATA=true
ALLOW_DESTRUCTIVE_SCHEMA_RESET=false

# PayU (test mode) — merchant key + 32-char salt; never expose salt to the browser
PAYU_MERCHANT_KEY=your_merchant_key
PAYU_SALT=your_32_char_salt
PAYU_BASE_URL=https://test.payu.in/_payment
PAYU_SUCCESS_URL=http://localhost:8000/api/v1/payments/payu/return
PAYU_FAILURE_URL=http://localhost:8000/api/v1/payments/payu/return
FRONTEND_BASE_URL=http://localhost:3000
# Optional: 256-bit RSA private key (PayU advanced APIs)
# PAYU_RSA_PRIVATE_KEY=
