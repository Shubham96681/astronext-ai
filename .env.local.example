NEXT_PUBLIC_API_URL=http://localhost:8000
# Must match backend JWT_SECRET for middleware route protection
JWT_SECRET=astronext-dev-secret-change-in-production

# Shopify — live products from your store (public collection JSON by default)
SHOPIFY_STORE_DOMAIN=www.astronext.ai
SHOPIFY_MYSHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_COLLECTION_ID=gid://shopify/Collection/321156776094
SHOPIFY_COLLECTION_HANDLE=rudraksha-bracelets
SHOPIFY_API_VERSION=2024-01

# Optional: Admin GraphQL (shpat_ token) or OAuth client credentials
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_KEY=your_api_key
# SHOPIFY_API_SECRET=shpss_your_api_secret
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional: separate collection for /estore
# SHOPIFY_ESTORE_COLLECTION_ID=gid://shopify/Collection/321156776094
# SHOPIFY_ESTORE_COLLECTION_HANDLE=your-estore-handle
